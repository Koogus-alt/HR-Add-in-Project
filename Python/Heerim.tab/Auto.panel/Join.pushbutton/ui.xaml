<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Heerim Auto Join Manager" Height="650" Width="600"
        WindowStartupLocation="CenterScreen" Background="#F5F5F7"
        FontFamily="Segoe UI" FontSize="13" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">
    
    <Window.Resources>
        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#34C759"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="8"/>
                </Style>
            </Style.Resources>
        </Style>
        <!-- DataGrid 깔끔한 스타일 (선택 시 파란 바탕에 글씨 안보이는 것 방지) -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#E5E5E5" BorderThickness="1" CornerRadius="16" Background="White" MouseLeftButtonDown="Window_MouseDown" KeyDown="Window_KeyDown" Focusable="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="80"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="#FBFBFD" Margin="0,0,0,1">
                <TextBlock Text="Auto Join" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="25,0,0,0"/>
            </Grid>

            <!-- Content Area -->
            <Border Grid.Row="1" Padding="20">
                <StackPanel>
                    <TextBlock Text="결합 우선순위 설정 (위쪽이 우선)" FontWeight="Bold" Margin="0,0,0,10" Foreground="#424245"/>
                    
                    <ListBox Name="RuleList" Height="320" Background="White" BorderThickness="1" BorderBrush="#E5E5E5" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             AllowDrop="True" PreviewMouseLeftButtonDown="RuleList_PreviewMouseLeftButtonDown" PreviewMouseLeftButtonUp="RuleList_MouseUp" MouseMove="RuleList_MouseMove" Drop="RuleList_Drop" DragOver="RuleList_DragOver" DragLeave="RuleList_DragLeave">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="5,8"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                <Setter Property="AllowDrop" Value="True"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="40"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <TextBox Grid.Column="0" Text="{Binding Path=[rank], Mode=TwoWay}" Width="30" HorizontalAlignment="Center" TextAlignment="Center" VerticalAlignment="Center" LostFocus="Rank_LostFocus" KeyDown="Rank_KeyDown" BorderBrush="#E5E5E5" Background="#FBFBFD" Foreground="#1D1D1F" Margin="10,0,5,0"/>

                                    <ComboBox Grid.Column="1" HorizontalAlignment="Stretch" ItemsSource="{DynamicResource CategoryList}" SelectedValue="{Binding Path=[category], UpdateSourceTrigger=PropertyChanged}" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Margin="5,0"/>
                                    
                                    <Border Grid.Column="2" Background="Transparent" CornerRadius="4" Cursor="SizeAll" ToolTip="드래그하여 순서 변경">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#E5E5EA"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="≡" Foreground="#8E8E93" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="10,5"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Grid Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="+ 카테고리 추가" Click="AddRule" Background="Transparent" BorderThickness="0" Foreground="#0071E3" FontWeight="SemiBold"/>
                            <Button Content="- 카테고리 삭제" Click="RemoveRule" Background="Transparent" BorderThickness="0" Foreground="#FF3B30" FontWeight="SemiBold" Margin="15,0,0,0"/>
                            <Button Content="⚙ 카테고리 편집" Click="EditCategories" Background="Transparent" BorderThickness="0" Foreground="#424245" FontWeight="SemiBold" Margin="15,0,0,0" ToolTip="목록에 표시될 Revit 카테고리를 설정합니다."/>
                        </StackPanel>
                    </Grid>

                    <Separator Margin="0,15"/>

                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="작업 범위:" VerticalAlignment="Center" Foreground="#424245"/>
                            <RadioButton Name="ScopeView" Content="현재 뷰" IsChecked="True" VerticalAlignment="Center" Margin="10,0,0,0"/>
                            <RadioButton Name="ScopeSelection" Content="현재 선택" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <RadioButton Name="ModeJoin" Content="자동 결합" IsChecked="True" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <RadioButton Name="ModeUnjoin" Content="자동 결합 해제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Footer -->
            <Border Grid.Row="2" Background="#FBFBFD" Padding="25,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="취소" Width="100" Height="40" Margin="0,0,15,0" Click="CloseWindow" Background="#E5E5EA" Foreground="#1D1D1F" BorderThickness="0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="실행" Width="120" Height="40" Style="{StaticResource PrimaryButtonStyle}" Click="RunCommand"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
