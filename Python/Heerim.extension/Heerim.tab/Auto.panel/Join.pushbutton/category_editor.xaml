<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="카테고리 편집" Height="480" Width="350" WindowStartupLocation="CenterScreen" Background="#F5F5F7" ResizeMode="NoResize" FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="표시할 카테고리를 선택하세요:" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" Foreground="#1D1D1F"/>
        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Name="SearchBox" Grid.Column="0" Height="28" Padding="5,0,25,0" VerticalContentAlignment="Center" TextChanged="SearchBox_TextChanged"/>
            <TextBlock Text="🔍" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0" Foreground="#8E8E93" IsHitTestVisible="False"/>
            <Button Name="FilterBtn" Grid.Column="1" Content="✔필터" Margin="8,0,0,0" Width="55" Height="28" Background="#E5E5EA" BorderThickness="0" Click="FilterBtn_Click" ToolTip="선택된 항목만 보기 토글"/>
        </Grid>
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="모두 선택 (Check All)" Click="CheckAll" Padding="8,4" Margin="0,0,10,0" Background="White" BorderBrush="#E5E5E5" BorderThickness="1"/>
            <Button Content="모두 해제 (Uncheck All)" Click="UncheckAll" Padding="8,4" Background="White" BorderBrush="#E5E5E5" BorderThickness="1"/>
        </StackPanel>
        <ListBox Grid.Row="3" Name="CatListBox" BorderThickness="1" BorderBrush="#E5E5E5" Background="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="0,5" Foreground="#424245"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="취소" Width="70" Height="30" Margin="0,0,10,0" Click="CloseBtn" Background="#E5E5EA" BorderThickness="0"/>
            <Button Content="확인" Width="70" Height="30" Click="OKBtn" Background="#34C759" Foreground="White" BorderThickness="0"/>
        </StackPanel>
    </Grid>
</Window>
