<Window x:Class="Heerim_SheetsAndView.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Heerim Sheets &amp; Views" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" Background="#F5F5F7">
        <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <Style x:Key="DataGridRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDependentView}" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
<Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Padding="15" Background="White" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
    <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="heerim" FontSize="20" FontWeight="Bold" Foreground="#333333" FontStyle="Italic"/>
                    <TextBlock Text=" Architects &amp; Planners" FontSize="10" VerticalAlignment="Bottom" Foreground="#757575" Margin="5,0,0,4"/>
                </StackPanel>
                <TextBlock Text="HEERIM Sheets &amp; Views" HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold" Foreground="#2196F3"/>
            </Grid>
        </Border>

        <!-- Main Content (Tabs) -->
        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Create View">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <WrapPanel VerticalAlignment="Center" Grid.Column="0">
                            <Button Foreground="#333" Background="#F0F0F0" Command="{Binding AddViewCommand}" CommandParameter="{Binding ElementName=NewViewCountBox, Path=Text}" Padding="8,4" Margin="0,0,5,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="New View" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBox x:Name="NewViewCountBox" Text="1" Width="30" TextAlignment="Center" VerticalAlignment="Center" BorderThickness="1" BorderBrush="#CCC"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Delete" Command="{Binding DeleteViewCommand}" Padding="8,4" Margin="0,0,5,5" Background="#F0F0F0"/>
                            <Button Content="Duplicate as a Dependent" Command="{Binding DuplicateDependentCommand}" Padding="8,4" Margin="0,0,5,5" Background="#F0F0F0"/>
                            <Button Content="Import / Export" Padding="8,4" Margin="0,0,5,5" Background="#F0F0F0"/>
                            <Button Content="Parameters" Padding="8,4" Margin="0,0,5,5" Background="#F0F0F0"/>
                        </WrapPanel>
                        <Grid Grid.Column="1" VerticalAlignment="Top" Margin="5,0,0,5">
                            <TextBox x:Name="SearchBox" Width="200" Padding="5,2" BorderThickness="1" BorderBrush="#CCC" TextChanged="SearchBox_TextChanged"/>
                            <TextBlock IsHitTestVisible="False" Text="🔍 이름/레벨/스코프 검색..." Foreground="#999" Margin="7,3" FontStyle="Italic">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Grid>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding ViewItems}" AutoGenerateColumns="False" CanUserAddRows="False" 
                              Background="White" BorderBrush="#E0E0E0" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F0F0F0">
                        <DataGrid.RowStyle>
                            <StaticResource ResourceKey="DataGridRowStyle"/>
                        </DataGrid.RowStyle>
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E6F2FF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E6F2FF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header=" " Width="30">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Dimension" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding Category}" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="View Name" Width="2*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <!-- Expand/Collapse Button (Only for parents with children) -->
                                            <ToggleButton IsChecked="{Binding IsExpanded}"
                                                          Command="{Binding DataContext.ToggleExpandCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                          CommandParameter="{Binding}"
                                                          Visibility="{Binding HasChildren, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                          Width="18" Height="18" Margin="0,0,5,0">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" BorderBrush="#DDD" BorderThickness="1" CornerRadius="2">
                                                            <TextBlock x:Name="BtnText" Text="+" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="#666"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="BtnText" Property="Text" Value="-"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            
                                            <!-- Indent for children WITHOUT button -->
                                            <Border Width="18" Visibility="{Binding IsDependentView, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,0,5,0"/>

                                            <TextBox x:Name="ViewNameBox" Text="{Binding ViewName, UpdateSourceTrigger=PropertyChanged}" 
                                                     BorderThickness="0" Background="Transparent" VerticalContentAlignment="Center"
                                                     MouseDoubleClick="DataGridTextBox_MouseDoubleClick">
                                                <TextBox.Style>
                                                    <Style TargetType="TextBox">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDependentView}" Value="True">
                                                                <Setter Property="FontWeight" Value="Normal"/>
                                                                <Setter Property="Foreground" Value="#444"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBox.Style>
                                            </TextBox>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Crop Area" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding CropButtonText}" 
                                                IsEnabled="{Binding IsCropAreaEnabled}"
                                                Background="Transparent" BorderThickness="0" FontWeight="Bold" Cursor="Hand"
                                                Command="{Binding DataContext.DrawBoxCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                CommandParameter="{Binding}">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="Foreground" Value="#2196F3"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsEnabled" Value="False">
                                                            <Setter Property="Foreground" Value="#CCCCCC"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <DataGridTemplateColumn Header="Level" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.Levels, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding LevelName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Scope Box" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ScopeBoxes, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding SelectedScopeBox, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="View Template" Width="120">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox ItemsSource="{Binding DataContext.ViewTemplates, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                                  SelectedItem="{Binding SelectedViewTemplate, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="Count" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Count, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" VerticalAlignment="Stretch" VerticalContentAlignment="Center" TextAlignment="Center" HorizontalAlignment="Stretch" FocusVisualStyle="{x:Null}" MinWidth="30" MouseDoubleClick="DataGridTextBox_MouseDoubleClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="Create Sheet">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="Import Excel" Command="{Binding ImportExcelCommand}" Padding="10,5" Margin="0,0,10,0"/>
                        <Button Content="Export Excel" Command="{Binding ExportExcelCommand}" Padding="10,5"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Row="1" Margin="0,0,0,10">
                        <TextBlock Text="Title Block" FontSize="10" Foreground="#666" Margin="0,0,0,2"/>
                        <ComboBox Width="300" HorizontalAlignment="Left" ItemsSource="{Binding TitleBlocks}" SelectedItem="{Binding SelectedTitleBlock}"/>
                    </StackPanel>
                    
                    <DataGrid Grid.Row="2" AutoGenerateColumns="False" ItemsSource="{Binding SheetItems}">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#E6F2FF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="Black"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="#E6F2FF"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="Black"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Select">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Sheet Number" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding SheetNumber, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" FocusVisualStyle="{x:Null}" MinWidth="30" MouseDoubleClick="DataGridTextBox_MouseDoubleClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="View Name" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding ViewName, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent" VerticalAlignment="Stretch" VerticalContentAlignment="Center" HorizontalAlignment="Stretch" FocusVisualStyle="{x:Null}" MinWidth="30" MouseDoubleClick="DataGridTextBox_MouseDoubleClick"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
            <TabItem Header="View in Sheet">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock Text="배치 설정" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Button Content="Auto Matching" Command="{Binding AutoMatchCommand}" Padding="10,5" Background="#E8F5E9" BorderBrush="#4CAF50"/>
                        </StackPanel>
                        <DataGrid Height="300" AutoGenerateColumns="False">
                            <DataGrid.RowStyle>
                                <StaticResource ResourceKey="DataGridRowStyle"/>
                            </DataGrid.RowStyle>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Sheet Name" Width="*"/>
                                <DataGridComboBoxColumn Header="Layout"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <Border Grid.Column="1" Margin="10,0,0,0" BorderBrush="#E0E0E0" BorderThickness="1" Background="White" CornerRadius="4">
    <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="LAYOUT PREVIEW (10x10)" HorizontalAlignment="Center" Margin="5" FontSize="10" Foreground="#757575"/>
                            
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding LayoutPoints}" Margin="5">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="10" Rows="10"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ToggleButton IsChecked="{Binding IsSelected}" Width="25" Height="25" Margin="1"
                                                      ToolTip="{Binding Number}" Padding="0">
                                            <TextBlock Text="{Binding Number}" FontSize="8"/>
                                        </ToggleButton>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Footer -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="Cancel" Width="80" Height="30" Margin="0,0,10,0" Click="OnCancelClick"/>
            <Button Content="Apply" Width="80" Height="30" Background="#2196F3" Foreground="White" Click="OnApplyClick"/>
        </StackPanel>
    </Grid>
</Window>
