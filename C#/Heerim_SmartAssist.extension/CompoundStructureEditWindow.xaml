<Window x:Class="Heerim_SmartAssist.CompoundStructureEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="조립품 편집" Height="450" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F2F2F7"
        KeyDown="Window_KeyDown">
        
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="복합 구조 (Compound Structure)" FontSize="14" FontWeight="Bold" Margin="10,10,10,5" Foreground="#1C1C1E"/>

        <Grid Grid.Row="1" Margin="10,5,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="LayersGrid" Grid.Column="0" ItemsSource="{Binding Layers}" AutoGenerateColumns="False" 
                      CanUserAddRows="False" CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserSortColumns="False"
                      GridLinesVisibility="All" VerticalGridLinesBrush="#E5E5EA" HorizontalGridLinesBrush="#E5E5EA"
                      BorderBrush="#C7C7CC" BorderThickness="1" Background="White" RowHeaderWidth="30">
                <DataGrid.Columns>
                    <!-- Function ComboBox -->
                    <DataGridTemplateColumn Header="기능" Width="110">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Function, UpdateSourceTrigger=PropertyChanged}" 
                                          SelectedValuePath="Value" DisplayMemberPath="Header"
                                          ItemsSource="{Binding DataContext.FunctionOptions, RelativeSource={RelativeSource AncestorType=Window}}"
                                          IsHitTestVisible="False" BorderThickness="0" Background="Transparent" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding Function, UpdateSourceTrigger=PropertyChanged}" 
                                          SelectedValuePath="Value" DisplayMemberPath="Header"
                                          ItemsSource="{Binding DataContext.FunctionOptions, RelativeSource={RelativeSource AncestorType=Window}}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <!-- Material ComboBox -->
                    <DataGridTemplateColumn Header="재질" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding MaterialId, UpdateSourceTrigger=PropertyChanged}" 
                                          SelectedValuePath="Id"
                                          ItemsSource="{Binding DataContext.AvailableMaterials, RelativeSource={RelativeSource AncestorType=Window}}"
                                          IsHitTestVisible="False" BorderThickness="0" Background="Transparent">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12" Height="12" Background="{Binding ColorHex}" BorderBrush="#C7C7CC" BorderThickness="1" Margin="0,0,5,0" CornerRadius="2"/>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox SelectedValue="{Binding MaterialId, UpdateSourceTrigger=PropertyChanged}" 
                                          SelectedValuePath="Id"
                                          ItemsSource="{Binding DataContext.AvailableMaterials, RelativeSource={RelativeSource AncestorType=Window}}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="12" Height="12" Background="{Binding ColorHex}" BorderBrush="#C7C7CC" BorderThickness="1" Margin="0,0,5,0" CornerRadius="2"/>
                                                <TextBlock Text="{Binding Name}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="두께 (mm)" Binding="{Binding ThicknessMM, StringFormat=F1, UpdateSourceTrigger=PropertyChanged}" Width="70">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                <Setter Property="Margin" Value="4,0"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridCheckBoxColumn Header="줄바꿈" Binding="{Binding Wraps, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                    <DataGridCheckBoxColumn Header="구조 재질" Binding="{Binding IsStructural, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <Button Content="삽입" Height="26" Margin="0,0,0,5" Click="OnInsertClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
                <Button Content="삭제" Height="26" Margin="0,0,0,15" Click="OnDeleteClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
                <Button Content="위로" Height="26" Margin="0,0,0,5" Click="OnUpClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
                <Button Content="아래로" Height="26" Margin="0,0,0,15" Click="OnDownClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Padding="10" Background="#F2F2F7" BorderThickness="0,1,0,0" BorderBrush="#C7C7CC">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="확인" Width="80" Height="26" Margin="0,0,10,0" Click="OnOkClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
                <Button Content="취소" Width="80" Height="26" Click="OnCancelClick" Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
