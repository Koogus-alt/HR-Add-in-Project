<Window x:Class="Heerim_SmartAssist.ParameterEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="특성" Height="600" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        Background="#F2F2F7"
        Topmost="True"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <CollectionViewSource x:Key="ParametersCVS" Source="{Binding Entries}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupName"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>

        <!-- Revit-style Expander Style -->
        <Style x:Key="RevitExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="#F2F2F7"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" FontWeight="Bold" Foreground="#1C1C1E" Margin="4,2"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Template for Booleans -->
        <DataTemplate x:Key="BoolTemplate">
            <CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                      HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0"/>
        </DataTemplate>

        <!-- Template for Enums (ComboBox) -->
        <DataTemplate x:Key="EnumTemplate">
            <ComboBox ItemsSource="{Binding AllowedValues}" 
                      SelectedValuePath="Id"
                      DisplayMemberPath="Name"
                      SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="False" Margin="2" BorderThickness="0" Background="Transparent"/>
        </DataTemplate>

        <!-- Template for Color Pickers -->
        <DataTemplate x:Key="ColorTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="14" Height="14" Margin="4,2" BorderBrush="#C7C7CC" BorderThickness="1" Background="{Binding ColorHexBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding ColorName}" Margin="4,2" VerticalAlignment="Center" Foreground="#1C1C1E"/>
                <Button Grid.ColumnSpan="2" Opacity="0" Click="OnColorButtonClick" Tag="{Binding}" Cursor="Hand"/>
            </Grid>
        </DataTemplate>

        <!-- Template for Fill Patterns (ComboBox with Images) -->
        <DataTemplate x:Key="FillPatternTemplate">
            <ComboBox ItemsSource="{Binding AllowedValues}" 
                      SelectedValuePath="Id"
                      SelectedValue="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      IsEditable="False" Margin="2" BorderThickness="0" Background="Transparent">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border Width="48" Height="16" Margin="0,0,6,0" BorderBrush="#C7C7CC" BorderThickness="1">
                                <Border.Background>
                                    <ImageBrush ImageSource="{Binding ThumbnailImage}" Stretch="None" AlignmentX="Left" AlignmentY="Top"/>
                                </Border.Background>
                            </Border>
                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" Foreground="#1C1C1E"/>
                        </StackPanel>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DataTemplate>

        <!-- Default TextBox Template -->
        <DataTemplate x:Key="DefaultTemplate">
            <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="2" BorderThickness="0" Background="Transparent"/>
        </DataTemplate>

        <!-- Readonly templates -->
        <DataTemplate x:Key="ReadOnlyBoolTemplate">
            <CheckBox IsChecked="{Binding BoolValue, Mode=OneWay}" 
                      HorizontalAlignment="Left" VerticalAlignment="Center" Margin="4,0" IsEnabled="False"/>
        </DataTemplate>
        <DataTemplate x:Key="ReadOnlyDefaultTemplate">
            <TextBlock Text="{Binding Value}" Margin="4,2" VerticalAlignment="Center"/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header: Image + Name -->
            <RowDefinition Height="Auto"/> <!-- SubHeader: Preset Name + Toggle -->
            <RowDefinition Height="*"/>    <!-- Properties Grid -->
            <RowDefinition Height="Auto"/> <!-- Apply Button -->
        </Grid.RowDefinitions>
        
        <!-- Header: Mimic Revit Properties TOP -->
        <Border Grid.Row="0" Background="#F2F2F7" BorderBrush="#C7C7CC" BorderThickness="0,0,0,1" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Width="48" Height="48" Background="White" BorderBrush="#D1D1D6" BorderThickness="1" CornerRadius="4">
                    <Image x:Name="ItemPreviewImage" Stretch="Uniform" Margin="2"/>
                </Border>
                
                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="ItemNameText" Text="개체 이름" FontWeight="Bold" FontSize="14" Foreground="#1C1C1E"/>
                    <TextBlock x:Name="ItemCategoryText" Text="카테고리" FontSize="11" Foreground="#8E8E93"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- SubHeader: Preset Name + Type Edit Button -->
        <Border Grid.Row="1" Background="#F2F2F7" BorderBrush="#C7C7CC" BorderThickness="0,0,0,1" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <TextBox x:Name="PresetNameTextBox" Grid.Column="0" Height="24" Padding="5,2" VerticalContentAlignment="Center"
                         Background="White" BorderBrush="#C7C7CC" BorderThickness="1" FontSize="12"
                         GotFocus="OnPresetNameTextBoxGotFocus"
                         PreviewMouseLeftButtonDown="OnPresetNameTextBoxPreviewMouseDown">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                <Button x:Name="TypeEditButton" Grid.Column="1" Content="유형 편집" Margin="10,0,0,0" 
                        Padding="10,2" FontSize="11" Click="OnTypeEditButtonClick" 
                        Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <!-- Properties Grid -->
        <Border Grid.Row="2" Background="White" BorderBrush="#C7C7CC" BorderThickness="0,0,0,1">
            <DataGrid x:Name="ParametersDataGrid"
                      ItemsSource="{Binding Source={StaticResource ParametersCVS}}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      CanUserResizeColumns="True"
                      HeadersVisibility="None"
                      GridLinesVisibility="All"
                      VerticalGridLinesBrush="#E5E5EA"
                      HorizontalGridLinesBrush="#E5E5EA"
                      BorderThickness="0"
                      RowBackground="#FFFFFF"
                      AlternatingRowBackground="#F9F9F9"
                      RowHeaderWidth="0"
                      SelectionUnit="Cell"
                      SelectionMode="Single"
                      Background="White">
                
                <DataGrid.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.ContainerStyle>
                            <Style TargetType="{x:Type GroupItem}">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="{x:Type GroupItem}">
                                            <Expander IsExpanded="True" Style="{StaticResource RevitExpanderStyle}">
                                                <Expander.Header>
                                                    <Binding Path="Name" />
                                                </Expander.Header>
                                                <ItemsPresenter />
                                            </Expander>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GroupStyle.ContainerStyle>
                    </GroupStyle>
                </DataGrid.GroupStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="4,2"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#E5E5EA"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}" 
                                            BorderThickness="{TemplateBinding BorderThickness}" 
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E3F2FD"/>
                                <Setter Property="Foreground" Value="#1C1C1E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Binding="{Binding Name}" IsReadOnly="True" Width="150">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Margin" Value="4,2"/>
                                <Setter Property="Foreground" Value="#1C1C1E"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ContentControl Content="{Binding}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="ContentTemplate" Value="{StaticResource DefaultTemplate}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBoolean}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource BoolTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEnumerable}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource EnumTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsColor}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource ColorTemplate}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsFillPattern}" Value="True">
                                                    <Setter Property="ContentTemplate" Value="{StaticResource FillPatternTemplate}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Footer: Apply/Apply Buttons -->
        <Border Grid.Row="3" Padding="10" Background="#F2F2F7">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="저장" Width="80" Height="26" Margin="0,0,10,0" Click="OnSaveClick" 
                        Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1" FontSize="11">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="취소" Width="80" Height="26" Click="OnCancelClick" 
                        Background="#FFFFFF" BorderBrush="#C7C7CC" BorderThickness="1" FontSize="11">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
