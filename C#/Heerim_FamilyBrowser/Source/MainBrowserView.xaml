<UserControl x:Class="Heerim_FamilyBrowser.MainBrowserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Heerim_FamilyBrowser"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F5F5F7">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar: Categories (Legacy Tree) -->
        <Border Grid.Column="0" BorderBrush="#E0E0E5" BorderThickness="0,0,1,0" Background="White">
            <DockPanel>
                <Label Content="HEERIM LIBRARY" DockPanel.Dock="Top" Margin="15,20,15,5" 
                       FontWeight="Bold" Foreground="#333" FontSize="14"/>
                <TreeView x:Name="CategoryTree" Margin="5" BorderThickness="0" 
                         SelectedItemChanged="CategoryTree_SelectedItemChanged">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding SubFolders}">
                            <TextBlock Text="{Binding Name}" Margin="2,4"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </DockPanel>
        </Border>

        <!-- Main Content: Family Items -->
        <DockPanel Grid.Column="1">
            <!-- Header/Search -->
            <Border DockPanel.Dock="Top" Height="60" Background="White" BorderBrush="#E0E0E5" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock x:Name="CategoryTitle" VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Select Category"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBox x:Name="SearchBox" Width="200" Height="28" VerticalContentAlignment="Center" 
                                 BorderBrush="#DADCE0" Padding="5,0"
                                 KeyUp="SearchBox_KeyUp"/>
                        <Button Content="Search" Margin="5,0,0,0" Width="60" Height="28" 
                                Background="#1A73E8" Foreground="White" BorderThickness="0"
                                Click="SearchButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Family List -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox x:Name="FamilyListBox" Margin="10" BorderThickness="0" Background="Transparent" 
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         SelectionChanged="FamilyListBox_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Width="160" Height="180" Margin="5" Padding="5" 
                                    Background="White" CornerRadius="8" BorderBrush="#E0E0E5" BorderThickness="1">
                                <StackPanel>
                                    <Image Source="{Binding Thumbnail}" Width="120" Height="120" Stretch="Uniform" Margin="0,5"/>
                                    <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="11" 
                                               TextAlignment="Center" TextWrapping="Wrap" Margin="2,5"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
