<Window x:Class="Heerim_SmartAssist.PresetListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="프리셋 관리" Height="450" Width="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7"
        Topmost="True">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#C7C7CC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F2F2F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundButtonStyle}">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="7"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style x:Key="BulkActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundButtonStyle}">
            <Setter Property="Padding" Value="10,2"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="FontSize" Value="10.5"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Height" Value="32"/>
        </Style>

        <Style x:Key="ActionButtonStyle" TargetType="Button" BasedOn="{StaticResource RoundButtonStyle}">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock x:Name="ItemNameText" Text="개체 이름" FontSize="18" FontWeight="Bold" Foreground="#1C1C1E"/>
                <TextBlock Text="이 개체에 설정된 커스텀 프리셋 목록입니다." FontSize="12" Foreground="#8E8E93" Margin="0,4,0,0"/>
            </StackPanel>
            
            <Border HorizontalAlignment="Right" Width="60" Height="60" CornerRadius="8" Background="White" BorderBrush="#D1D1D6" BorderThickness="1" Padding="2">
                <Image x:Name="ItemPreviewImage" Stretch="Uniform"/>
            </Border>
        </Grid>

        <!-- Search and List -->
        <Grid Grid.Row="1">
            <ListBox x:Name="PresetsListBox" 
                     Background="White" BorderBrush="#D1D1D6" BorderThickness="1"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     HorizontalContentAlignment="Stretch"
                     MouseDoubleClick="OnPresetsListBoxDoubleClick"
                     Padding="0">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderThickness" Value="0"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="10,12,10,12" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/> <!-- Checkbox for Edit Mode -->
                                    <ColumnDefinition Width="*"/>    <!-- Name and Tooltip -->
                                    <ColumnDefinition Width="Auto"/> <!-- Pencil Icon -->
                                    <ColumnDefinition Width="Auto"/> <!-- Trash Icon -->
                                </Grid.ColumnDefinitions>
                                
                                <!-- CheckBox: Visible only in EditMode -->
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,10,0"
                                          Visibility="{Binding DataContext.IsEditMode, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVis}}"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14" Foreground="#1C1C1E"/>
                                        <!-- Active State Dot: v138 -->
                                        <Ellipse Width="6" Height="6" Fill="#34C759" Margin="6,0,0,0" VerticalAlignment="Center"
                                                 Visibility="{Binding IsActive, Converter={StaticResource BoolToVis}}"/>
                                    </StackPanel>
                                    
                                    <ItemsControl ItemsSource="{Binding ParameterPills}" Margin="0,6,0,0">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border CornerRadius="6" Padding="6,3" Margin="0,0,6,6" BorderThickness="1">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="BorderBrush" Value="#007AFF"/>
                                                            <Setter Property="Background" Value="#F0F8FF"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsType}" Value="True">
                                                                    <Setter Property="BorderBrush" Value="#34C759"/>
                                                                    <Setter Property="Background" Value="#F2FDF2"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="11" Margin="0,0,4,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Foreground" Value="#005CBF"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsType}" Value="True">
                                                                            <Setter Property="Foreground" Value="#248A3D"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Value}" FontSize="11" Foreground="#48484A" MaxWidth="150" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
    
                                <!-- Pencil Icon Button -->
                                <Button Grid.Column="2" Style="{StaticResource IconButtonStyle}" Click="OnEditPresetClick" 
                                        ToolTip="프리셋 편집" VerticalAlignment="Top" Margin="5,0,0,0">
                                    <Path Width="11" Height="11" Data="M14.06,9.02L14.98,8.1L18.89,12.01L17.97,12.93L14.06,9.02M13.13,9.94L17.04,13.85L11.06,19.83C10.67,20.22 10.14,20.44 9.58,20.44H6.5V17.36C6.5,16.8 6.72,16.27 7.11,15.88L13.13,9.94M19.13,3.85L21.13,5.85C21.63,6.35 21.63,7.12 21.13,7.62L19.69,9.06L15.78,5.15L17.22,3.71C17.72,3.21 18.49,3.21 18.99,3.71L19.13,3.85Z" 
                                          Fill="#8E8E93" Stretch="Uniform"/>
                                </Button>
    
                                <!-- Trash Icon Button -->
                                <Button Grid.Column="3" Style="{StaticResource IconButtonStyle}" Click="OnDeleteIndividualPresetClick" 
                                        ToolTip="삭제" VerticalAlignment="Top" Margin="5,0,0,0">
                                    <Path Width="11" Height="11" Data="M9,3V4H4V6H5V19A2,2 0 0,0 7,21H17A2,2 0 0,0 19,19V6H20V4H15V3H9M7,6H17V19H7V6M9,8V17H11V8H9M13,8V17H15V8H13Z" 
                                          Fill="#8E8E93" Stretch="Uniform"/>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Footer Actions -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="85"/>
            </Grid.ColumnDefinitions>

            <!-- Mode-dependent controls (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- Bulk Actions: Visible only in Edit Mode -->
                <StackPanel Orientation="Horizontal" Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                    <Button Content="전체 선택" Style="{StaticResource BulkActionButtonStyle}" Click="OnSelectAllClick"/>
                    <Button Content="전체 해제" Style="{StaticResource BulkActionButtonStyle}" Click="OnDeselectAllClick"/>
                    <Button Content="선택 삭제" Style="{StaticResource BulkActionButtonStyle}" Click="OnDeleteSelectedClick" Background="#FF3B30" Foreground="White" BorderThickness="0"/>
                    <!-- v143: X button styled as bulk action for consistency and visibility -->
                    <Button Content="X" Style="{StaticResource BulkActionButtonStyle}" Click="OnDeletePresetClick" MinWidth="40"/>
                </StackPanel>
                
                <!-- Normal Mode Actions -->
                <StackPanel Orientation="Horizontal">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="+" Style="{StaticResource ActionButtonStyle}" Click="OnAddPresetClick" ToolTip="새 프리셋 추가" Foreground="#34C759" Margin="0,0,10,0"/>
                    <Button Content="-" Style="{StaticResource ActionButtonStyle}" Click="OnDeletePresetClick" ToolTip="편집 모드 전환" Foreground="#FF3B30" Margin="0,0,10,0"/>
                </StackPanel>
            </StackPanel>

            <!-- Close Button (Fixed Right Area) -->
            <Button Grid.Column="1" Content="닫기" IsCancel="True" Width="80" Height="32" Click="OnCloseClick"
                    Style="{StaticResource RoundButtonStyle}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>
    </Grid>
</Window>
