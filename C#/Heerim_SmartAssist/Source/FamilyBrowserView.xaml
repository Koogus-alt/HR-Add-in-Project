<Page x:Class="Heerim_SmartAssist.FamilyBrowserView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="300"
      Title="Smart Assist"
      Background="#F2F2F7"
      Focusable="True"
      Loaded="OnPageLoaded">

    <Page.Resources>
        <!-- Converters and other resources -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        
        <CollectionViewSource x:Key="FavoritesCVS" Source="{Binding FavoritesItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoryName"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="CategoryName" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <!-- Separate CVS for split Favorites -->
        <CollectionViewSource x:Key="FavoriteAnnotateCVS" Source="{Binding FavoritesItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoryName"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="CategoryName" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <CollectionViewSource x:Key="FavoriteFamilyCVS" Source="{Binding FavoritesItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoryName"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="CategoryName" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <CollectionViewSource x:Key="FamilyCVS" Source="{Binding FamilyItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupHeader"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="GroupHeader" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>
        <CollectionViewSource x:Key="AnnotateCVS" Source="{Binding AnnotateItems}">
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="GroupHeader"/>
            </CollectionViewSource.GroupDescriptions>
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="GroupHeader" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <!-- UI Styles -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="TextBox" x:Key="SearchBoxStyle">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D1D6"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,5,8,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <!-- Search Icon -->
                                <Path Fill="#8E8E93" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.02,15.15C12.05,15.77 10.82,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z" 
                                      Width="16" Height="16" Stretch="Uniform" HorizontalAlignment="Left" Margin="8,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                
                                <!-- Placeholder -->
                                <TextBlock x:Name="Placeholder" Text="검색어 입력..." Foreground="#C7C7CC" FontSize="{TemplateBinding FontSize}" 
                                           HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" IsHitTestVisible="False"
                                           Visibility="Hidden"/>
                                
                                <!-- Text Input -->
                                <ScrollViewer x:Name="PART_ContentHost" Margin="0" Background="Transparent"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="Text" Value="{x:Null}">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox" x:Key="CategoryComboStyle">
            <Setter Property="Height" Value="28"/>
            <Setter Property="Width" Value="130"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E5EA"/>
            <Setter Property="Foreground" Value="#1D1D1F"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5,0,0,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="Button" x:Key="IconButtonStyle">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="Transparent" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <GroupStyle x:Key="ExpandableGroupStyle">
            <GroupStyle.ContainerStyle>
                <Style TargetType="{x:Type GroupItem}">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="{x:Type GroupItem}">
                                <Expander IsExpanded="True" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Background="Transparent">
                                    <Expander.Style>
                                        <Style TargetType="Expander">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Expander">
                                                        <HeaderedContentControl Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                                            <HeaderedContentControl.Header>
                                                                <ToggleButton IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" VerticalAlignment="Center" HorizontalAlignment="Stretch" Background="Transparent" BorderThickness="0">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Padding="5,10">
                                                                                <Grid>
                                                                                    <Grid.ColumnDefinitions>
                                                                                        <ColumnDefinition Width="Auto"/>
                                                                                        <ColumnDefinition Width="*"/>
                                                                                    </Grid.ColumnDefinitions>
                                                                                    
                                                                                    <!-- +/- Symbol -->
                                                                                    <Border Width="16" Height="16" CornerRadius="2" BorderBrush="#1D1D1F" BorderThickness="1.2" Background="#FFFFFF" VerticalAlignment="Center">
                                                                                        <TextBlock x:Name="Symbol" Text="-" FontWeight="Bold" FontSize="11" Foreground="#1D1D1F" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                                                                                    </Border>

                                                                                    <!-- Category Name Label -->
                                                                                    <ContentPresenter Grid.Column="1" Content="{Binding Header, RelativeSource={RelativeSource AncestorType=Expander}}" 
                                                                                                    Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                                                </Grid>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="False">
                                                                                    <Setter TargetName="Symbol" Property="Text" Value="+"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="Symbol" Property="Background" Value="#F2F2F7"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                            </HeaderedContentControl.Header>
                                                            <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" />
                                                        </HeaderedContentControl>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsExpanded" Value="True">
                                                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Expander.Style>
                                    <Expander.Header>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13" Foreground="#1D1D1F"/>
                                    </Expander.Header>
                                    <ItemsPresenter />
                                </Expander>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </GroupStyle.ContainerStyle>
        </GroupStyle>

        <!-- Shared Favorite Toggle Style (Premium Ghost Circle) -->
        <Style x:Key="FavoriteToggleStyle" TargetType="ToggleButton">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <!-- Circular Hover Background (Ghost Circle) -->
                            <Border x:Name="HoverCircle" 
                                    Background="Transparent" 
                                    CornerRadius="14" 
                                    Opacity="0.1"/>
                            
                            <Viewbox Margin="{TemplateBinding Padding}">
                                <Path x:Name="StarPath" 
                                      Stroke="#34C759" 
                                      StrokeThickness="2" 
                                      Fill="Transparent"
                                      Data="M 12 2 L 15.09 8.26 L 22 9.27 L 17 14.14 L 18.18 21.02 L 12 17.77 L 5.82 21.02 L 7 14.14 L 2 9.27 L 8.91 8.26 L 12 2 Z"/>
                            </Viewbox>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="StarPath" Property="Fill" Value="#34C759"/>
                                <Setter TargetName="StarPath" Property="Opacity" Value="1.0"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="StarPath" Property="Opacity" Value="0.5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverCircle" Property="Background" Value="#34C759"/>
                                <Setter TargetName="StarPath" Property="Opacity" Value="1.0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- v130: Preset Management Button Style (Ellipse dots) -->
        <Style x:Key="PresetManageButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="HoverCircle" Background="Transparent" CornerRadius="12" Opacity="0.1"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse Width="3" Height="3" Fill="#8E8E93" Margin="1,0"/>
                                <Ellipse Width="3" Height="3" Fill="#8E8E93" Margin="1,0"/>
                                <Ellipse Width="3" Height="3" Fill="#8E8E93" Margin="1,0"/>
                            </StackPanel>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HoverCircle" Property="Background" Value="#8E8E93"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Family Item Template (Grid Style) -->
        <DataTemplate x:Key="FamilyItemTemplate">
            <Grid Margin="3" Width="116">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="24"/>  <!-- Star column (left side) -->
                    <ColumnDefinition Width="*"/>   <!-- Preview + Name column -->
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="96"/>   <!-- Preview row -->
                    <RowDefinition Height="Auto"/>  <!-- Name row - auto to prevent clipping -->
                </Grid.RowDefinitions>


                <!-- Col 0: Star (Favorite toggle) on the LEFT SIDE, at the top -->
                <ToggleButton Grid.Column="0" Grid.Row="0"
                              IsChecked="{Binding IsFavorite}"
                              Click="OnFavoriteClick"
                              Style="{StaticResource FavoriteToggleStyle}"
                              HorizontalAlignment="Center" VerticalAlignment="Top"
                              Margin="0,4,0,0">
                </ToggleButton>

                <!-- v130: Preset management button instead of text indicator -->
                <Button Grid.Column="0" Grid.Row="0" 
                        Click="OnManagePresetClick"
                        Style="{StaticResource PresetManageButtonStyle}"
                        ToolTip="커스텀 파라미터 관리"
                        HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,32,0,0"/>

                <!-- Col 1: Preview box + Name (clickable) -->
                <Button Grid.Column="1" Grid.Row="0" Grid.RowSpan="2"
                        Click="OnItemClick" Background="Transparent" BorderThickness="0"
                        HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                    <StackPanel>
                        <!-- White Preview Border with selection state -->
                        <Border CornerRadius="8" Background="#FFFFFF" Margin="0,0,4,0" Height="96">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="#34C759"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                        </DataTrigger>
                                        <!-- v156: Unified Active state trigger for grid view -->
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="BorderBrush" Value="#34C759"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                            <Setter Property="Background" Value="#E8F9ED"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Image Source="{Binding Image}" Stretch="Uniform" Margin="6"/>
                        </Border>
                        <!-- Name -->
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextTrimming="CharacterEllipsis"
                                   MaxHeight="28"
                                   FontSize="11"
                                   Foreground="#424245"
                                   ToolTip="{Binding Name}"/>
                            <!-- Active Preset Name: v141 -->
                            <TextBlock Text="{Binding ActivePresetDisplayName, StringFormat='({0})'}"
                                   FontSize="10" 
                                   Foreground="#34C759"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis"
                                   Visibility="{Binding HasActivePreset, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>
            </Grid>
        </DataTemplate>

        <!-- Family Item Template (List Style) - NEW for v31 -->
        <DataTemplate x:Key="FamilyListItemTemplate">
            <Border Height="44">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E5EA"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#E8F9ED"/>
                                <Setter Property="BorderBrush" Value="#34C759"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <!-- v154: Active state trigger for family list -->
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#E8F9ED"/>
                                <Setter Property="BorderBrush" Value="#34C759"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/> <!-- v130: Manage button column -->
                    </Grid.ColumnDefinitions>

                    <!-- Favorite toggle on the left (Keep separate from main click) -->
                    <ToggleButton Grid.Column="0"
                                  IsChecked="{Binding IsFavorite}" 
                                  Click="OnFavoriteClick"
                                  Style="{StaticResource FavoriteToggleStyle}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                    </ToggleButton>

                    <!-- Clickable area covering icon and name -->
                    <Button Grid.Column="1" Click="OnItemClick" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Small Preview Icon -->
                            <Border Grid.Column="0" Width="28" Height="28" Background="#FFFFFF" CornerRadius="4" VerticalAlignment="Center" Margin="2" BorderBrush="#E5E5EA" BorderThickness="1">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                <Setter Property="BorderBrush" Value="#34C759"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Image Source="{Binding Image}" Stretch="Uniform" Margin="2"/>
                            </Border>

                            <!-- Name on the right -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                                <TextBlock Text="{Binding ParametersDisplay}" ToolTip="{Binding ParametersTooltip}" Foreground="#007AFF" FontSize="10" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding DisplayName}" 
                                           FontSize="12"
                                           Foreground="#1D1D1F"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <!-- Active Preset Name: v141 -->
                                <TextBlock Text="{Binding ActivePresetDisplayName, StringFormat=' ({0})'}"
                                           FontSize="11"
                                           Foreground="#34C759"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasActivePreset, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Grid>
                    </Button>

                    <!-- v130: Manage button on the right end -->
                    <Button Grid.Column="2" 
                            Click="OnManagePresetClick"
                            Style="{StaticResource PresetManageButtonStyle}"
                            ToolTip="커스텀 파라미터 관리"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AnnotateItemTemplate">
            <Border Height="44">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="BorderBrush" Value="#E5E5EA"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Background" Value="#E8F9ED"/>
                                <Setter Property="BorderBrush" Value="#34C759"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                            <!-- v154: Active state trigger for annotate list -->
                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                <Setter Property="Background" Value="#E8F9ED"/>
                                <Setter Property="BorderBrush" Value="#34C759"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/> <!-- v130: Manage button column -->
                    </Grid.ColumnDefinitions>

                    <!-- Favorite toggle on the left -->
                    <ToggleButton Grid.Column="0"
                                  IsChecked="{Binding IsFavorite}" 
                                  Click="OnFavoriteClick"
                                  Style="{StaticResource FavoriteToggleStyle}"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center">
                    </ToggleButton>

                    <!-- Name Part (Clickable) -->
                    <Button Grid.Column="1" Click="OnItemClick" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left" VerticalContentAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="5,0,0,0">
                            <TextBlock Text="{Binding ParametersDisplay}" ToolTip="{Binding ParametersTooltip}" Foreground="#007AFF" FontSize="10" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding DisplayName}" 
                                       FontSize="12"
                                       Foreground="#1D1D1F"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"/>
                            <!-- Active Preset Name: v141 -->
                            <TextBlock Text="{Binding ActivePresetDisplayName, StringFormat=' ({0})'}"
                                       FontSize="11"
                                       Foreground="#34C759"
                                       FontWeight="SemiBold"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding HasActivePreset, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                        </StackPanel>
                    </Button>

                    <!-- v130: Manage button on the right end -->
                    <Button Grid.Column="2" 
                            Click="OnManagePresetClick"
                            Style="{StaticResource PresetManageButtonStyle}"
                            ToolTip="커스텀 파라미터 관리"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"/>
                </Grid>
            </Border>
        </DataTemplate>
        <Style x:Key="ViewModeButtonStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="#F2F2F7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#F5F5F7">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
            <RowDefinition Height="Auto"/> <!-- Global Header -->
            <RowDefinition Height="Auto"/> <!-- Spacer -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Active Preset Status Bar: v138 -->
        <Border Grid.Row="0" x:Name="ActivePresetStatusBar" Background="#E8F5E9" BorderBrush="#34C759" BorderThickness="0,0,0,1" 
                Visibility="Collapsed" Padding="10,4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Ellipse Width="8" Height="8" Fill="#34C759" Margin="0,0,8,0"/>
                <TextBlock Text="활성 프리셋: " FontSize="11" Foreground="#2E7D32" FontWeight="SemiBold"/>
                <TextBlock x:Name="ActivePresetNameText" Text="Preset Name" FontSize="11" Foreground="#1B5E20" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="10,12">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Revit 2026 Smart Assist" FontSize="16" FontWeight="Bold" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                
                <!-- Refresh Button moved to title right -->
                <Button Click="OnRefreshClick" Style="{StaticResource IconButtonStyle}" Margin="8,0,0,0" ToolTip="데이터 새로고침">
                    <Path Fill="#34C759" Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                </Button>
                <!-- Library Explorer Button (Book Icon) -->
                <Button Click="OnLibraryClick" Style="{StaticResource IconButtonStyle}" Margin="4,0,0,0" ToolTip="Heerim 서버 라이브러리 탐색기">
                    <Viewbox Width="16" Height="16">
                        <Path Fill="#007AFF" Data="M19,2L14,6.5V17.5L19,13V2M6.5,2C4,2 2,4 2,6.5V21H12.5V6.5C12.5,4 10.5,2 8,2H6.5M8,4.5C9.4,4.5 10.5,5.6 10.5,7V19H4V6.5C4,5.1 5.1,4 6.5,4H8Z" Stretch="Uniform"/>
                    </Viewbox>
                </Button>
                <Button x:Name="SettingsBtn" Click="OnSettingsClick" Style="{StaticResource IconButtonStyle}" Margin="4,0,0,0" ToolTip="설정">
                    <Path Fill="#8E8E93" Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,1,0,1" Padding="0,0" Height="0">
        </Border>

        <TabControl x:Name="MainTabControl" Grid.Row="3" Margin="5" Background="Transparent" BorderThickness="0" SelectedIndex="0">
            <TabItem Header="Favorites">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="10,8">
                        <TextBox x:Name="SearchBoxFavorites" Style="{StaticResource SearchBoxStyle}" Width="250" HorizontalAlignment="Left" TextChanged="SearchBoxFavorites_TextChanged" />
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <StackPanel x:Name="FavoritesContentPanel">
                                <!-- Annotate Favorites Section -->
                                <TextBlock x:Name="FavAnnotateHeader" Text="Annotate" FontWeight="Bold" FontSize="14" Margin="10,10,0,5" Foreground="#1D1D1F"/>
                                <ItemsControl x:Name="FavAnnotateList" ItemsSource="{Binding Source={StaticResource FavoriteAnnotateCVS}}" 
                                              ItemTemplate="{StaticResource AnnotateItemTemplate}"
                                              Margin="5,0,5,10">
                                    <ItemsControl.GroupStyle>
                                        <StaticResource ResourceKey="ExpandableGroupStyle"/>
                                    </ItemsControl.GroupStyle>
                                </ItemsControl>

                                <!-- Family Favorites Section -->
                                <Border Margin="10,15,5,5" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="FavFamilyHeader" Text="Family" FontWeight="Bold" FontSize="14" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                                        
                                        <Border Grid.Column="1" Padding="4,2" Background="#F2F2F7" CornerRadius="4" BorderBrush="#E5E5EA" BorderThickness="1" Margin="0,0,5,5">
                                            <StackPanel Orientation="Horizontal" Background="#FFFFFF">
                                                <RadioButton x:Name="FavGridViewBtn" GroupName="FavViewMode" Style="{StaticResource ViewModeButtonStyle}" IsChecked="True" Click="OnFavModeClick" ToolTip="Grid View">
                                                    <Viewbox Width="14" Height="14">
                                                        <Path x:Name="FavGridIcon" Fill="#34C759" Data="M4,11V13H10V11H4M4,18V20H10V18H4M4,4V6H10V4H4M14,11V13H20V11H14M14,18V20H20V18H14M14,4V6H20V4H14Z"/>
                                                    </Viewbox>
                                                </RadioButton>
                                                <RadioButton x:Name="FavListViewBtn" GroupName="FavViewMode" Style="{StaticResource ViewModeButtonStyle}" IsChecked="False" Click="OnFavModeClick" ToolTip="List View">
                                                    <Viewbox Width="14" Height="14">
                                                        <Path x:Name="FavListIcon" Fill="#8E8E93" Data="M3,4H21V6H3V4M3,11H21V13H3V11M3,18H21V20H3V18Z"/>
                                                    </Viewbox>
                                                </RadioButton>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>
                                
                                <ItemsControl x:Name="FavFamilyList" ItemsSource="{Binding Source={StaticResource FavoriteFamilyCVS}}" 
                                              ItemTemplate="{StaticResource FamilyItemTemplate}"
                                              Margin="5,0,5,10">
                                    <ItemsControl.GroupStyle>
                                        <StaticResource ResourceKey="ExpandableGroupStyle"/>
                                    </ItemsControl.GroupStyle>
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                            
                            <!-- Empty State Message -->
                            <StackPanel x:Name="FavoritesEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,50,0,0" Visibility="Collapsed">
                                <Path Fill="#C7C7CC" Data="M12,17.27L18.18,21L16.54,13.97L22,9.24L14.81,8.62L12,2L9.19,8.62L2,9.24L7.45,13.97L5.82,21L12,17.27Z" Width="48" Height="48" Stretch="Uniform" HorizontalAlignment="Center" Opacity="0.5"/>
                                <TextBlock Text="자주 사용하는 항목의 별표를 클릭하여" Foreground="#8E8E93" FontSize="14" HorizontalAlignment="Center" Margin="0,15,0,2"/>
                                <TextBlock Text="이 곳에 편리하게 모아보세요." Foreground="#8E8E93" FontSize="14" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            <TabItem Header="Family">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Search Bar and View Mode Toggle (v35) -->
                    <Border Grid.Row="0" Margin="5,5,5,2" Background="Transparent" BorderThickness="0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="SearchBoxFamily" Grid.Column="0" Style="{StaticResource SearchBoxStyle}" HorizontalAlignment="Stretch" TextChanged="SearchBoxFamily_TextChanged"/>
                            
                            <ComboBox x:Name="CategoryFamilyCombo" Grid.Column="1" Style="{StaticResource CategoryComboStyle}" SelectionChanged="CategoryFamilyCombo_SelectionChanged"/>
                            
                            <Border Grid.Column="2" Padding="8,4" Background="#F2F2F7" CornerRadius="6" BorderBrush="#E5E5EA" BorderThickness="1" Margin="5,0,0,0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Background="#FFFFFF">
                                <RadioButton x:Name="GridViewBtn" GroupName="ViewMode" Style="{StaticResource ViewModeButtonStyle}" IsChecked="True" Click="OnModeClick" ToolTip="Grid View">
                                    <Viewbox Width="16" Height="16">
                                        <Path x:Name="GridIcon" Fill="#34C759" Data="M4,11V13H10V11H4M4,18V20H10V18H4M4,4V6H10V4H4M14,11V13H20V11H14M14,18V20H20V18H14M14,4V6H20V4H14Z"/>
                                    </Viewbox>
                                </RadioButton>
                                <RadioButton x:Name="ListViewBtn" GroupName="ViewMode" Style="{StaticResource ViewModeButtonStyle}" IsChecked="False" Click="OnModeClick" ToolTip="List View">
                                    <Viewbox Width="16" Height="16">
                                        <Path x:Name="ListIcon" Fill="#8E8E93" Data="M3,4H21V6H3V4M3,11H21V13H3V11M3,18H21V20H3V18Z"/>
                                    </Viewbox>
                                </RadioButton>
                            </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="FamilyItemsControl" 
                                      ItemsSource="{Binding Source={StaticResource FamilyCVS}}" 
                                      ItemTemplate="{StaticResource FamilyItemTemplate}">
                            <ItemsControl.GroupStyle>
                                <StaticResource ResourceKey="ExpandableGroupStyle"/>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel x:Name="FamilyWrapPanel" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
            
            <TabItem Header="Annotate">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <Border Grid.Row="0" Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="10,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBox x:Name="SearchBoxAnnotate" Grid.Column="0" Style="{StaticResource SearchBoxStyle}" HorizontalAlignment="Stretch" TextChanged="SearchBoxAnnotate_TextChanged" />

                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ComboBox x:Name="CategoryAnnotateCombo" Style="{StaticResource CategoryComboStyle}" SelectionChanged="CategoryAnnotateCombo_SelectionChanged"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="AnnotateItemsControl" 
                                      ItemsSource="{Binding Source={StaticResource AnnotateCVS}}" 
                                      ItemTemplate="{StaticResource AnnotateItemTemplate}">
                            <ItemsControl.GroupStyle>
                                <StaticResource ResourceKey="ExpandableGroupStyle"/>
                            </ItemsControl.GroupStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel x:Name="AnnotateStackPanel" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
