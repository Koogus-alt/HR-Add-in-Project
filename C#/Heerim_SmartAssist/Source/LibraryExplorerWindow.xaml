<Window x:Class="Heerim_SmartAssist.LibraryExplorerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Heerim Library Explorer" 
        Width="900" Height="650"
        MinWidth="700" MinHeight="450"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F7">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Search Bar -->
            <RowDefinition Height="*"/>      <!-- Content -->
            <RowDefinition Height="Auto"/>   <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                        <Path Fill="#007AFF" Data="M19,2L14,6.5V17.5L19,13V2M6.5,2C4,2 2,4 2,6.5V21H12.5V6.5C12.5,4 10.5,2 8,2H6.5M8,4.5C9.4,4.5 10.5,5.6 10.5,7V19H4V6.5C4,5.1 5.1,4 6.5,4H8Z" Stretch="Uniform"/>
                    </Viewbox>
                    <TextBlock Text="Heerim Library Explorer" FontSize="18" FontWeight="Bold" Foreground="#1D1D1F" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="2" x:Name="LibraryPathText" Text="" FontSize="11" Foreground="#8E8E93" VerticalAlignment="Center" Margin="10,0"/>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" Background="#FBFBFD" BorderBrush="#E5E5EA" BorderThickness="0,0,0,1" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Border Background="#FFFFFF" BorderBrush="#D1D1D6" BorderThickness="1" CornerRadius="6" Padding="8,4">
                    <Grid>
                        <Path Fill="#8E8E93" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L19.71,19L18.29,20.41L13.02,15.15C12.05,15.77 10.82,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"
                              Width="14" Height="14" Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0"/>
                        <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" FontSize="13" 
                                 Padding="22,2,4,2" VerticalContentAlignment="Center"
                                 TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="SearchPlaceholder" Text="패밀리 검색..." Foreground="#C7C7CC" FontSize="13"
                                   Margin="24,0,0,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                   Visibility="Visible"/>
                    </Grid>
                </Border>
                <TextBlock Grid.Column="1" x:Name="ResultCountText" Text="0개 항목" FontSize="12" Foreground="#8E8E93"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
            </Grid>
        </Border>

        <!-- Main Content: TreeView + Gallery -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="150"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Category Tree -->
            <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="카테고리" FontWeight="SemiBold" FontSize="13" Foreground="#1D1D1F" Margin="12,10,12,8"/>
                    <TreeView x:Name="CategoryTree" Grid.Row="1" BorderThickness="0" Background="Transparent" 
                              SelectedItemChanged="CategoryTree_SelectedItemChanged"
                              Padding="4,0"/>
                </Grid>
            </Border>

            <!-- Splitter -->
            <GridSplitter Grid.Column="1" Width="3" Background="#E5E5EA" HorizontalAlignment="Center" VerticalAlignment="Stretch"/>

            <!-- Right: Family Gallery -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <WrapPanel x:Name="FamilyGallery" Margin="10"/>
                    
                    <!-- Empty State -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                        <Viewbox Width="64" Height="64" Opacity="0.3" Margin="0,0,0,16">
                            <Path Fill="#8E8E93" Data="M19,2L14,6.5V17.5L19,13V2M6.5,2C4,2 2,4 2,6.5V21H12.5V6.5C12.5,4 10.5,2 8,2H6.5M8,4.5C9.4,4.5 10.5,5.6 10.5,7V19H4V6.5C4,5.1 5.1,4 6.5,4H8Z" Stretch="Uniform"/>
                        </Viewbox>
                        <TextBlock Text="좌측 카테고리를 선택하세요" Foreground="#8E8E93" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Text="패밀리 미리보기가 여기에 표시됩니다" Foreground="#C7C7CC" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#FFFFFF" BorderBrush="#E5E5EA" BorderThickness="0,1,0,0" Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText" Text="라이브러리 경로를 설정해주세요" FontSize="11" Foreground="#8E8E93" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="LoadButton" Content="프로젝트에 로드" Click="OnLoadClick" IsEnabled="False"
                            Background="#007AFF" Foreground="White" FontWeight="SemiBold" FontSize="13"
                            Padding="20,8" BorderThickness="0" Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#0056B3"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="bg" Property="Background" Value="#C7C7CC"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
